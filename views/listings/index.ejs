<% layout("/layouts/boilerplate") %>
<style>

/* ===== FILTER BAR ===== */
#filter-wrapper {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.5rem;
    padding: 0.8rem 0 0.5rem;
    border-bottom: 1px solid #ebebeb;
    margin-bottom: 1.5rem;
}

#filters {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 1.5rem;
    padding-bottom: 0.4rem;
    position: relative;
    width: 100%;
    scrollbar-width: none;
    -ms-overflow-style: none;
}

#filters::-webkit-scrollbar {
    display: none;
}

#filters::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 48px;
    background: linear-gradient(to left, white 60%, transparent);
    pointer-events: none;
}

.filter {
    flex: 0 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    min-width: 64px;
    cursor: pointer;
    padding-bottom: 6px;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s, opacity 0.2s;
    opacity: 0.6;
}

.filter:hover {
    opacity: 1;
    border-bottom: 2px solid #222;
}

.filter.active {
    opacity: 1;
    border-bottom: 2px solid #222;
}

.filter i {
    font-size: 22px;
    color: #444 !important;
}

.filter p {
    font-size: 11px;
    font-weight: 600;
    margin: 0;
    color: #444;
    white-space: nowrap;
}

/* ===== TAX TOGGLE ===== */
.tax-toggle {
    flex-shrink: 0;
    white-space: nowrap;
}

.tax-toggle .form-check-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #333;
}

/* ===== TAX INFO ===== */
.tax-info {
    display: none;
    font-size: 0.82rem;
    color: #888;
    font-style: normal;
}

/* ===== MOBILE ===== */
@media (max-width: 768px) {
    #filter-wrapper {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.8rem;
        padding: 0.6rem 0 0.4rem;
    }

    .tax-toggle {
        width: 100%;
    }

    .filter i { font-size: 20px; }
    .filter p  { font-size: 10px; }
}

</style>

<!-- Filter Bar -->
<div id="filter-wrapper">
    <div id="filters">

        <div class="filter">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-bed"></i>
            <p>Rooms</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-city"></i>
            <p>Iconic City</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-chess-rook"></i>
            <p>Castle</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-person-swimming"></i>
            <p>Pool</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-campground"></i>
            <p>Camping</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-cow"></i>
            <p>Farming</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-umbrella-beach"></i>
            <p>Beach</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-ferry"></i>
            <p>Ships</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-tree"></i>
            <p>Forest</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-igloo"></i>
            <p>Arctic</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-water"></i>
            <p>Lakefront</p>
        </div>
        <div class="filter">
            <i class="fa-solid fa-gem"></i>
            <p>Luxury</p>
        </div>

    </div>

    <!-- Tax Toggle -->
    <div class="tax-toggle">
        <div class="form-check form-switch form-check-reverse">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Show taxes</label>
        </div>
    </div>
</div>

<!-- Listings Grid -->
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% for(let listing of allListings) { %>
    <div class="col">
        <a href="/listings/<%=listing._id%>" class="listing-link text-decoration-none">
            <div class="card h-100 listing-card">
                <img src="<%=listing.image.url%>" class="card-img-top img-fluid" alt="listing-img" style="height: 20rem; object-fit: cover;">
                <div class="card-img-overlay">Tap to View More</div>
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %></b><br>
                        &#8377; <%= listing.price ? Number(listing.price).toLocaleString("en-IN") : "0" %>/night
                        <span class="tax-info">&nbsp;+18% GST</span>
                    </p>
                </div>
            </div>
        </a>
    </div>
    <% } %>
</div>

<script>
    // Tax toggle
    const taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("change", () => {
        document.querySelectorAll(".tax-info").forEach(el => {
            el.style.display = taxSwitch.checked ? "inline" : "none";
        });
    });

    // Active filter highlight on click
    document.querySelectorAll(".filter").forEach(filter => {
        filter.addEventListener("click", () => {
            document.querySelectorAll(".filter").forEach(f => f.classList.remove("active"));
            filter.classList.add("active");
        });
    });
</script>
