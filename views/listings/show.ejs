<% layout("/layouts/boilerplate") %> 
<script>
    window.maptilerKey = "<%= maptilerKey %>"; 
</script>

<div class="container py-4" style="max-width: 800px;">

    <!-- Title -->
    <h3 class="fw-bold mb-3"><%= listing.title %></h3>

    <!-- Listing Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <img src="<%= listing.image.url %>" class="card-img-top show-img rounded-4" alt="Listing Image">
        <div class="card-body px-4 py-3">
            <p class="text-muted small mb-1"><i>Hosted by <strong><%= listing.owner[0].username %></strong></i></p>
            <p class="mb-2"><%= listing.description %></p>
            <p class="fw-bold fs-5 mb-1" style="color:#fe424d;">&#8377;<%= listing.price.toLocaleString("en-IN") %><span class="fw-normal fs-6 text-muted">/night</span></p>
            <p class="mb-1 text-secondary"><i class="fa-solid fa-location-dot me-1" style="font-size:0.9rem;"></i><%= listing.location %></p>
            <p class="mb-0 text-secondary"><i class="fa-solid fa-earth-asia me-1" style="font-size:0.9rem;"></i><%= listing.country %></p>
        </div>
    </div>

    <!-- Owner Actions -->
    <% if(currUser && listing.owner[0]._id.equals(currUser._id)){ %>
    <div class="d-flex gap-2 mb-4">
        <form action="/listings/<%=listing._id%>/edit" method="get">
            <button class="btn btn-dark rounded-3 px-4 edit-btn">Edit</button>
        </form>
        <form action="/listings/<%=listing._id%>?_method=DELETE" method="post">
            <button class="btn btn-outline-danger rounded-3 px-4">Delete</button>
        </form>
    </div>
    <% } %>

    <hr class="my-4">

    <!-- Leave Review -->
    <% if(currUser) { %>
    <div class="mb-5">
        <h5 class="fw-bold mb-3">Leave a Review</h5>
        <div class="card border-0 bg-light rounded-4 p-4">
            <form action="/listings/<%=listing._id%>/reviews" method="post" novalidate class="needs-validation">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Rating</label>
                    <div class="rating-box" id="rating-stars">
                        <i class="fa-solid fa-star rating-star" data-value="1"></i>
                        <i class="fa-solid fa-star rating-star" data-value="2"></i>
                        <i class="fa-solid fa-star rating-star" data-value="3"></i>
                        <i class="fa-solid fa-star rating-star" data-value="4"></i>
                        <i class="fa-solid fa-star rating-star" data-value="5"></i>
                    </div>
                    <input type="hidden" name="review[rating]" id="rating-value" value="0" required>
                </div>
                <div class="mb-3">
                    <label for="comment" class="form-label fw-semibold">Comment</label>
                    <textarea name="review[comment]" rows="4" class="form-control rounded-3" placeholder="Share your experience..." required></textarea>
                    <div class="invalid-feedback">Please add a comment before submitting.</div>
                </div>
                <button class="btn btn-outline-success rounded-3 px-4">Submit Review</button>
            </form>
        </div>
    </div>
    <% } %>

    <!-- All Reviews -->
    <% if(listing.reviews.length > 0){ %>
    <div class="mb-5">
        <h5 class="fw-bold mb-3">All Reviews</h5>
        <div class="row g-3">
            <% for (review of listing.reviews) { %>
            <div class="col-12 col-md-6">
                <div class="card border rounded-4 h-100 shadow-sm p-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div class="rounded-circle bg-danger text-white d-flex align-items-center justify-content-center fw-bold"
                             style="width:36px; height:36px; font-size:0.85rem; flex-shrink:0;">
                            <%= review.author.username.charAt(0).toUpperCase() %>
                        </div>
                        <span class="fw-semibold"><%= review.author.username %></span>
                    </div>
                    <div class="mb-2">
                        <% for (let i = 1; i <= 5; i++) { %>
                            <% if (i <= review.rating) { %>
                                <i class="fa-solid fa-star" style="color:gold; font-size:14px;"></i>
                            <% } else { %>
                                <i class="fa-regular fa-star" style="color:gold; font-size:16px;"></i>
                            <% } %>
                        <% } %>
                    </div>
                    <p class="text-secondary small mb-2 flex-grow-1"><%= review.comment %></p>
                    <% if(currUser && review.author._id.equals(currUser._id)){ %>
                    <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post" class="mt-auto">
                        <button class="btn btn-sm btn-outline-secondary rounded-3">Delete</button>
                    </form>
                    <% } %>
                </div>
            </div>
            <% } %>
        </div>
    </div>
    <% } %>
    

<!-- Book This Place -->
<div class="mb-5">
    <h5 class="fw-bold mb-3">Book This Place</h5>
    <div class="booking-card rounded-4 p-4">

        <!-- Price Header -->
        <div class="d-flex align-items-baseline gap-1 mb-4">
            <span class="fw-bold fs-4" style="color:#fe424d;">&#8377;<span id="b-price-per-night"><%= listing.price.toLocaleString("en-IN") %></span></span>
            <span class="text-muted">/night</span>
        </div>

        <!-- Form Fields -->
        <div class="mb-3">
            <label class="form-label" for="b-name">Your Name</label>
            <input type="text" id="b-name" class="form-control" placeholder="Enter your full name" oninput="calcBookingPrice()" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="b-days">Number of Days</label>
            <input type="number" id="b-days" class="form-control" placeholder="e.g. 3" min="1" max="365" oninput="calcBookingPrice()" />
        </div>

        <!-- Price Breakdown (hidden until filled) -->
        <div id="b-breakdown" class="booking-breakdown rounded-3 p-3 mb-3" style="display:none;">
            <div class="d-flex justify-content-between small text-muted mb-1">
                <span>&#8377;<span id="b-rate"><%= listing.price.toLocaleString("en-IN") %></span> × <span id="b-days-display">0</span> nights</span>
                <span>&#8377;<span id="b-subtotal">0</span></span>
            </div>
            <div class="d-flex justify-content-between small text-muted mb-1">
                <span>Service fee (5%)</span>
                <span>&#8377;<span id="b-fee">0</span></span>
            </div>
            <hr class="my-2">
            <div class="d-flex justify-content-between fw-bold">
                <span>Total</span>
                <span style="color:#fe424d;">&#8377;<span id="b-total">0</span></span>
            </div>
        </div>

        <!-- Book Button -->
        <button id="b-btn" class="btn w-100 book-btn rounded-3 py-2 fw-bold" onclick="confirmBooking()" disabled>
            <i class="fa-solid fa-calendar-check me-2" style="color:#fff; font-size:1rem;"></i>Book Now
        </button>

    </div>
</div>


<!-- ✅ SUCCESS POPUP MODAL — Paste this ANYWHERE inside the <div class="container"> but after the booking card above -->
<div id="booking-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center;">
    <div class="booking-success-modal rounded-4 p-5 text-center">
        <!-- Animated checkmark -->
        <div class="check-circle mb-3">
            <i class="fa-solid fa-check" style="color:#fff; font-size:1.8rem;"></i>
        </div>
        <h4 class="fw-bold mb-1">Hotel Booked Successfully!</h4>
        <p class="text-muted small mb-1" id="b-confirm-name"></p>
        <p class="text-muted small mb-3" id="b-confirm-details"></p>
        <div class="booking-total-pill mb-4" id="b-confirm-total"></div>
        <button class="btn btn-dark rounded-3 px-5 py-2 fw-bold" onclick="closeBookingModal()">Done</button>
    </div>
</div>


<%# ✅ PASTE THIS <script> block just BEFORE </div> at the very end of the container --%>
<script>
    const rawPrice = <%= listing.price %>;

    function fmtINR(n) {
        return Math.round(n).toLocaleString("en-IN");
    }

    function calcBookingPrice() {
        const days  = parseInt(document.getElementById("b-days").value) || 0;
        const name  = document.getElementById("b-name").value.trim();
        const breakdown = document.getElementById("b-breakdown");
        const btn = document.getElementById("b-btn");

        if (days > 0 && name.length > 0) {
            const subtotal = rawPrice * days;
            const fee      = Math.round(subtotal * 0.05);
            const total    = subtotal + fee;

            document.getElementById("b-days-display").textContent = days;
            document.getElementById("b-subtotal").textContent     = fmtINR(subtotal);
            document.getElementById("b-fee").textContent          = fmtINR(fee);
            document.getElementById("b-total").textContent        = fmtINR(total);

            breakdown.style.display = "block";
            btn.disabled = false;
        } else {
            breakdown.style.display = "none";
            btn.disabled = true;
        }
    }

    function confirmBooking() {
        const name  = document.getElementById("b-name").value.trim();
        const days  = parseInt(document.getElementById("b-days").value) || 0;
        const subtotal = rawPrice * days;
        const fee      = Math.round(subtotal * 0.05);
        const total    = subtotal + fee;

        document.getElementById("b-confirm-name").textContent    = `Booked by: ${name}`;
        document.getElementById("b-confirm-details").textContent = `${days} night${days > 1 ? "s" : ""} at ₹${fmtINR(rawPrice)}/night`;
        document.getElementById("b-confirm-total").textContent   = `Total Paid: ₹${fmtINR(total)}`;

        const overlay = document.getElementById("booking-overlay");
        overlay.style.display = "flex";
        document.body.style.overflow = "hidden";
    }

    function closeBookingModal() {
        document.getElementById("booking-overlay").style.display = "none";
        document.body.style.overflow = "";
        // Reset form
        document.getElementById("b-name").value  = "";
        document.getElementById("b-days").value  = "";
        document.getElementById("b-breakdown").style.display = "none";
        document.getElementById("b-btn").disabled = true;
    }
</script>


    <!-- Map -->
    <div class="mb-5">
        <h5 class="fw-bold mb-3 text-center">Where You'll Be</h5>
        <div id="map"
             style="height: 480px; width: 100%; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,0.12);"
             data-lng="<%= listing.longitude %>"
             data-lat="<%= listing.latitude %>"
             data-title="<%= listing.title %>"
             data-location="<%= listing.location %>">
        </div>
    </div>

</div>

<!-- MapLibre -->
<link href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css" rel="stylesheet" />
<script src="https://unpkg.com/maplibre-gl/dist/maplibre-gl.js"></script>
<script src="/js/map.js" defer></script>
